body{
  font-family: Arial;
  text-align: center;
  background: #f0f8ff;
}

h2{
  color: #333;
}

input{
  padding: 8px;
  margin: 10px;
  border: 1px solid #ccc;
}

button{
  padding: 8px 15px;
  background: #4CAF50;
  color: white;
  border: none;
  cursor: pointer;
}

button:hover{
  background: #45a049;
}

#result{
  font-weight: bold;
  margin-top: 10px;
}
